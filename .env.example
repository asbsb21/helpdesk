# Пример переменных окружения. Скопируйте в .env и заполните.

# Секретный ключ Django (для продакшена сгенерируйте случайный)
SECRET_KEY=django-insecure-dev-key-change-me

# Режим отладки: True локально, False на проде
DEBUG=True

# Разрешённые хосты (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1

# База данных. Локально можно не задавать (будет SQLite).
# Для PostgreSQL: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgres://user:password@localhost:5432/helpdesk

# Доверенные источники для CSRF на проде (через запятую), например:
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
